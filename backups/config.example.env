# Copy to backups/config.env and adjust. Do not commit config.env.
# Used by scripts/backup-pki.sh and scripts/restore-pki.sh.
# Host OS: Linux or macOS (see backups/runbook.md).

# Age recipients file (public keys only). Generate with:
#   age-keygen -o identity.txt
#   grep '^# public key:' identity.txt | sed 's/^# public key: //' > backups/age-recipient.txt
# Or copy the age1... line from age-keygen stdout.
# Install age: macOS `brew install age`; Linux distro package or GitHub releases.
AGE_RECIPIENT_FILE=backups/age-recipient.txt

# NAS / second host via SSH (rsync). Leave NAS_HOST empty to default to --no-rsync behavior
# unless you pass an explicit destination.
NAS_USER=pki-backup
NAS_HOST=nas.local
NAS_PATH=/volume1/my-cloud-pki-backups

# Retention keep-counts used with --prune (newest N by name sort)
KEEP_DUMPS=8
KEEP_SECRETS=5
KEEP_MANIFESTS=8

# Optional: clear local staging ciphertext after a successful rsync (1=yes, 0=keep)
CLEAR_STAGING_AFTER_RSYNC=0
