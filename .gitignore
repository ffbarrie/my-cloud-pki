# Environment files — only .env.example files are tracked
.env
.env.*
!.env.example
!offline-ca/.env.example
!bootstrap/.env.example

# Local certificate profiles — only *.cnf.example is tracked
offline-ca/profiles/*.cnf
!offline-ca/profiles/*.cnf.example
bootstrap/profiles/*.cnf
!bootstrap/profiles/*.cnf.example

# Bootstrap software CA working state (keys, certs, serials)
bootstrap/artifacts/

# EST local secrets and enrollment scratch (keys, RA password, test CSRs)
est/artifacts/
est/aliases/est.properties
est/artifacts/est.env

# EJBCA / MariaDB local data (also covered by issuing-ca/.gitignore)
issuing-ca/data/
