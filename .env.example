# Copy to .env and adjust for your lab. Do not commit real secrets.
# Only .env.example belongs in git; other .env* files are ignored.
#
# Policy:
#   https://github.com/ffbarrie/my-cloud/blob/main/docs/adr/0004-ejbca-online-issuing-ca.md
#   https://github.com/ffbarrie/my-cloud/blob/main/docs/adr/0005-postgresql-datastore.md

COMPOSE_PROJECT_NAME=my-cloud-pki

# EJBCA Community (online issuing CA)
EJBCA_IMAGE_TAG=latest
EJBCA_HOSTNAME=ejbca
EJBCA_HTTP_PORT=8080
EJBCA_HTTPS_PORT=8443
EJBCA_TLS_SETUP_ENABLED=simple
EJBCA_LOG_LEVEL_APP=INFO
EJBCA_LOG_LEVEL_SERVER=INFO

# PostgreSQL used by EJBCA — change the password before first start
EJBCA_DB_NAME=ejbca
EJBCA_DB_USER=ejbca
EJBCA_DB_PASSWORD=change-me-ejbca-db
