# Copy to root-ca.cnf and customize for your lab. Local *.cnf files are gitignored.
# Bootstrap only — not the HSM offline root.
# Policy: https://github.com/ffbarrie/my-cloud/blob/main/docs/adr/0003-pki-certificate-naming.md
# Runbook: ../software-root-ca.md

[ req ]
default_bits       = 4096
prompt             = no
default_md         = sha256
distinguished_name = req_distinguished_name
x509_extensions    = v3_ca

[ req_distinguished_name ]
CN = My Cloud Bootstrap Root CA
O  = My Cloud
OU = PKI

[ v3_ca ]
basicConstraints     = critical, CA:true
keyUsage             = critical, keyCertSign, cRLSign
subjectKeyIdentifier = hash
